{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "allow-open-url",
    "dialog:allow-open",
    "dialog:allow-save",
    "core:event:default",
    "allow-get-api-config",
    "allow-import-database",
    "allow-export-database"
  ]
}